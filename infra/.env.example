# ─────────────────────────────────────────────────────────────────────────────
# Dialed App — environment variable template
#
# Copy this file to infra/.env and fill in real values before running
# `docker compose up`.  The .env file is gitignored and must NEVER be
# committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic (required for AI suggestion generation) ────────────────────────
# Obtain a key at https://console.anthropic.com
# Without this key the ai and ai-worker containers will start but every
# suggestion job will fail.
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (optional — used by telemetry ingestion for Whisper transcription) ─
OPENAI_API_KEY=

# ── Supabase JWT (required by the gateway for user authentication) ────────────
SUPABASE_JWT_SECRET=

# ── Internal service token (shared across all backend services) ───────────────
# Use a long random string in production.
INTERNAL_SECRET=dev-internal-secret
